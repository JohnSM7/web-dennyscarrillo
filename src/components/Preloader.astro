---
---
<div id="preloader" class="fixed inset-0 z-[100] bg-ink-950 flex items-center justify-center">
  <div class="relative flex flex-col items-center gap-8">
    <div class="relative">
      <div class="absolute inset-0 rounded-full bg-gold-gradient blur-2xl opacity-70 animate-glow"></div>
      <img
        src="/logo.png"
        alt="DC"
        width="90"
        height="120"
        class="relative w-[90px] h-auto drop-shadow-[0_0_30px_rgba(201,162,75,0.6)]"
      />
    </div>
    <div class="w-56 h-[2px] bg-white/10 overflow-hidden rounded-full">
      <div id="preloader-bar" class="h-full w-0 bg-gradient-to-r from-gold-500 via-gold-300 to-gold-100"></div>
    </div>
    <div class="font-mono text-[10px] tracking-[0.4em] uppercase text-white/50" id="preloader-pct">0%</div>
  </div>
</div>

<script>
  const pre = document.getElementById('preloader');
  const bar = document.getElementById('preloader-bar');
  const pct = document.getElementById('preloader-pct');
  let progress = 0;

  const tick = () => {
    progress = Math.min(progress + Math.random() * 12 + 4, 100);
    if (bar) bar.style.width = progress + '%';
    if (pct) pct.textContent = Math.floor(progress) + '%';
    if (progress < 100) {
      setTimeout(tick, 80);
    }
  };
  tick();

  const hide = () => {
    if (!pre) return;
    pre.style.transition = 'opacity .8s ease, transform .8s ease';
    pre.style.opacity = '0';
    pre.style.transform = 'scale(1.05)';
    setTimeout(() => {
      pre.style.display = 'none';
      document.body.classList.add('is-ready');
      window.dispatchEvent(new CustomEvent('app:ready'));
    }, 800);
  };

  window.addEventListener('load', () => {
    const start = Date.now();
    const wait = () => {
      if (progress >= 100 && Date.now() - start > 500) {
        hide();
      } else {
        requestAnimationFrame(wait);
      }
    };
    wait();
  });
</script>
