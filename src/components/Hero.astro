---
import { getLangFromUrl, useTranslations, type Lang } from '~/i18n/ui';
import HeroCanvas from './HeroCanvas.vue';
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const h = t('hero');
---

<section id="home" class="relative min-h-[100svh] overflow-hidden flex items-center pt-28 pb-20">
  <!-- Animated canvas -->
  <HeroCanvas client:visible />

  <!-- Portrait -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Wrapper de posicionamiento (no tocar con GSAP) -->
    <div class="absolute right-[-22%] sm:right-[-10%] md:right-[-2%] lg:right-[-1%] top-[42%] sm:top-[44%] md:top-[44%] -translate-y-1/2 w-[108%] sm:w-[94%] md:w-[80%] lg:w-[68%] xl:w-[62%] max-w-[960px] opacity-60 md:opacity-100">
      <!-- Elemento animado por GSAP — parallax transforms aquí, aisladas del posicionamiento -->
      <div class="hero-portrait relative">
        <!-- Glow dorado detrás -->
        <div class="absolute inset-0 bg-gold-gradient blur-[80px] opacity-30 animate-glow"></div>
        <!-- Imagen con máscara radial: bordes difuminados para fundirse con el fondo -->
        <img
          src="/fotos/imgPrincipal.png"
          alt="Dennys Carrillo"
          class="hero-portrait-img relative w-full h-auto object-contain mix-blend-screen"
        />
      </div>
    </div>
    <!-- Gradient ambient accents -->
    <div class="absolute right-[10%] top-[10%] w-48 md:w-64 h-48 md:h-64 rounded-full bg-gold-500/30 blur-[100px]"></div>
    <div class="absolute right-[8%] bottom-[15%] w-60 md:w-80 h-60 md:h-80 rounded-full bg-gold-100/25 blur-[120px]"></div>
  </div>

  <!-- Content -->
  <div class="container-x relative z-10">
    <div class="max-w-3xl">
      <div class="mb-6 chip hero-eyebrow">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-gold-500 animate-pulse"></span>
        <span class="text-white/80">{h.eyebrow}</span>
      </div>

      <h1 class="font-display text-[clamp(3rem,9vw,8.5rem)] leading-[0.88] font-extrabold tracking-[-0.02em]">
        <span class="hero-line block"><span class="hero-char-wrap">{h.title_1}</span></span>
        <span class="hero-line block"><span class="gradient-text">{h.title_2}</span></span>
        <span class="hero-line block italic font-light"><span class="gold-text">{h.title_3}</span></span>
      </h1>

      <p class="hero-sub mt-8 max-w-xl text-base md:text-lg text-white/70 leading-relaxed">
        {h.subtitle}
      </p>

      <div class="hero-cta mt-8 md:mt-10 flex flex-col xs:flex-row flex-wrap gap-3 sm:gap-4">
        <a href="#music" class="btn-primary group w-full sm:w-auto" data-cursor="hover">
          <span class="inline-flex w-6 h-6 sm:w-7 sm:h-7 rounded-full bg-ink-950/20 items-center justify-center">
            <svg width="10" height="12" viewBox="0 0 10 12" fill="currentColor"><path d="M10 6L0 12V0z"/></svg>
          </span>
          {h.cta_listen}
        </a>
        <a href="#contact" class="btn-ghost w-full sm:w-auto" data-cursor="hover">
          {h.cta_book}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 7h12M7 1l6 6-6 6"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 z-10 hero-scroll">
    <span class="font-mono text-[10px] tracking-[0.4em] uppercase text-white/50">{h.scroll}</span>
    <div class="w-[1px] h-14 bg-white/15 relative overflow-hidden">
      <div class="absolute inset-x-0 h-8 bg-gradient-to-b from-gold-100 to-transparent scroll-line"></div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-ink-950 pointer-events-none"></div>
</section>

<script>
  import { gsap } from 'gsap';

  const run = () => {
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    tl.from('.hero-eyebrow', { y: 20, opacity: 0, duration: 0.8 })
      .from('.hero-line', {
        y: 120,
        opacity: 0,
        duration: 1.1,
        stagger: 0.12,
        skewY: 4,
      }, '-=0.4')
      .from('.hero-sub', { y: 24, opacity: 0, duration: 0.9 }, '-=0.6')
      .from('.hero-cta > *', {
        y: 20,
        opacity: 0,
        duration: 0.7,
        stagger: 0.1,
      }, '-=0.5')
      .from('.hero-portrait', {
        opacity: 0,
        scale: 1.08,
        x: 80,
        duration: 1.5,
        ease: 'power2.out',
      }, '-=1.6')
      .from('.hero-scroll', { opacity: 0, y: -10, duration: 0.7 }, '-=0.3');

    // Subtle parallax on mouse
    const portrait = document.querySelector<HTMLElement>('.hero-portrait');
    if (portrait) {
      window.addEventListener('mousemove', (e) => {
        const x = (e.clientX / window.innerWidth - 0.5) * 20;
        const y = (e.clientY / window.innerHeight - 0.5) * 20;
        gsap.to(portrait, { x: x, y: y, duration: 1.2, ease: 'power2.out' });
      }, { passive: true });
    }

    // Scroll indicator line
    gsap.fromTo('.scroll-line',
      { y: -40 },
      { y: 56, duration: 2.2, repeat: -1, ease: 'power1.inOut' }
    );
  };

  if (document.readyState === 'complete') {
    window.addEventListener('app:ready', run, { once: true });
    setTimeout(run, 2500);
  } else {
    window.addEventListener('app:ready', run, { once: true });
  }
</script>

<style>
  /* Máscara radial agresiva: el rostro nítido, todo lo demás fade hasta transparente.
     Elimina los bordes negros del PNG original sin dejar contornos visibles. */
  .hero-portrait-img {
    -webkit-mask-image: radial-gradient(
      ellipse 55% 55% at 50% 40%,
      #000 15%,
      rgba(0, 0, 0, 0.92) 32%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0.2) 72%,
      transparent 85%
    );
            mask-image: radial-gradient(
      ellipse 55% 55% at 50% 40%,
      #000 15%,
      rgba(0, 0, 0, 0.92) 32%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0.2) 72%,
      transparent 85%
    );
    -webkit-mask-repeat: no-repeat;
            mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
            mask-size: 100% 100%;
  }
</style>
