---
import { getLangFromUrl, useTranslations, switchPath, type Lang } from '~/i18n/ui';
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const nav = t('nav');
const otherLang: Lang = lang === 'es' ? 'en' : 'es';
const otherPath = switchPath(Astro.url.pathname, otherLang);

const homeHref = lang === 'es' ? '/' : '/en/';
const blogHref = lang === 'es' ? '/blog/' : '/en/blog/';

// En páginas internas (blog individual, etc), los anchors deben apuntar a la home.
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/en/' || Astro.url.pathname === '/en';
const anchor = (hash: string) => (isHome ? hash : homeHref + hash);

const links = [
  { href: anchor('#home'), label: nav.home },
  { href: anchor('#bio'), label: nav.bio },
  { href: anchor('#music'), label: nav.music },
  { href: anchor('#events'), label: nav.events },
  { href: anchor('#gallery'), label: nav.gallery },
  { href: blogHref, label: nav.blog },
  { href: anchor('#contact'), label: nav.contact },
];
---

<header
  id="site-nav"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-500"
>
  <div class="container-x flex items-center justify-between h-[72px] md:h-[84px]">
    <a href={homeHref} class="group flex items-center gap-3" data-cursor="hover" aria-label="Dennys Carrillo">
      <img src="/logo.png" alt="DC" class="w-8 h-auto drop-shadow-[0_0_15px_rgba(201,162,75,0.5)] transition-transform group-hover:scale-110" />
      <span class="font-display font-bold text-sm tracking-[0.3em] text-white/90 hidden sm:block">
        DENNYS<span class="text-gold">.</span>CARRILLO
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-8">
      {links.map((l) => (
        <a
          href={l.href}
          class="font-mono text-[11px] tracking-[0.28em] uppercase text-white/70 hover:text-white transition-colors relative group"
          data-cursor="hover"
        >
          {l.label}
          <span class="absolute -bottom-1 left-0 w-0 h-[1.5px] bg-tropic-gradient transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={otherPath}
        class="font-mono text-[11px] tracking-[0.28em] uppercase text-white/70 hover:text-white transition-colors border border-white/15 rounded-full px-3.5 py-1.5 hover:border-tropic-aqua/50"
        data-cursor="hover"
      >
        {otherLang.toUpperCase()}
      </a>
      <a href="#contact" class="hidden md:inline-flex btn-primary !px-5 !py-2.5 !text-xs" data-cursor="hover">
        {nav.booking}
      </a>
      <button
        id="menu-toggle"
        class="lg:hidden w-10 h-10 grid place-items-center rounded-full border border-white/15 text-white"
        aria-label="Menu"
        data-cursor="hover"
      >
        <span class="relative block w-4 h-[1.5px] bg-white before:content-[''] before:absolute before:-top-1.5 before:left-0 before:w-4 before:h-[1.5px] before:bg-white after:content-[''] after:absolute after:top-1.5 after:left-0 after:w-4 after:h-[1.5px] after:bg-white"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-ink-950/95 backdrop-blur-xl pointer-events-none opacity-0 transition-opacity duration-500"
>
  <div class="absolute inset-0 bg-tropic-gradient opacity-10"></div>
  <div class="relative h-full flex flex-col items-center justify-center gap-6">
    {links.map((l) => (
      <a
        href={l.href}
        class="mobile-link font-display text-4xl font-bold text-white/90 hover:gradient-text transition-all"
      >
        {l.label}
      </a>
    ))}
    <a href="#contact" class="mobile-link btn-primary mt-6">{nav.booking}</a>
  </div>
</div>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 40) {
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.remove('nav-scrolled');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const closeMenu = () => {
    menu?.classList.remove('is-open');
    if (menu) {
      menu.style.opacity = '0';
      menu.style.pointerEvents = 'none';
    }
    document.body.style.overflow = '';
  };
  const openMenu = () => {
    menu?.classList.add('is-open');
    if (menu) {
      menu.style.opacity = '1';
      menu.style.pointerEvents = 'auto';
    }
    document.body.style.overflow = 'hidden';
  };

  toggle?.addEventListener('click', () => {
    if (menu?.classList.contains('is-open')) closeMenu();
    else openMenu();
  });
  menu?.querySelectorAll('.mobile-link').forEach((l) => {
    l.addEventListener('click', () => closeMenu());
  });
</script>

<style>
  #site-nav.nav-scrolled {
    background: rgba(5, 3, 10, 0.72);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
</style>
