---
import { getLangFromUrl, useTranslations, type Lang } from '~/i18n/ui';
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const e = t('events');

const rows = [
  { d: '—', city: '—', venue: '—' },
  { d: '—', city: '—', venue: '—' },
  { d: '—', city: '—', venue: '—' },
];
---

<section id="events" class="relative py-20 sm:py-24 md:py-40 overflow-hidden">
  <!-- Accent -->
  <div class="absolute -top-40 right-0 w-[500px] h-[500px] rounded-full bg-gold-500/20 blur-[120px]"></div>

  <div class="container-x relative">
    <div class="grid lg:grid-cols-12 gap-10 mb-14">
      <div class="lg:col-span-7">
        <div class="chip mb-6 reveal">
          <span class="w-1 h-1 rounded-full bg-gold-300"></span>
          {e.chip}
        </div>
        <h2 class="reveal font-display text-[clamp(2.25rem,5vw,4.5rem)] leading-[0.95] font-bold tracking-tight">
          <span class="block">{e.title}</span>
          <span class="block gradient-text italic font-light">{e.status}.</span>
        </h2>
      </div>
      <div class="lg:col-span-5 lg:pt-12">
        <p class="reveal text-white/70 mb-6">{e.subtitle}</p>
        <a href="#contact" class="btn-primary" data-cursor="hover">
          {e.book}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 7h12M7 1l6 6-6 6"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Events table placeholder -->
    <div class="reveal rounded-3xl border border-white/10 overflow-hidden bg-white/[0.02] backdrop-blur">
      <!-- Headers (solo en md+) -->
      <div class="hidden md:grid grid-cols-12 px-6 md:px-10 py-5 font-mono text-[10px] tracking-[0.3em] uppercase text-white/40 border-b border-white/5">
        <div class="col-span-3">Date</div>
        <div class="col-span-4">City</div>
        <div class="col-span-4">Venue</div>
        <div class="col-span-1 text-right">—</div>
      </div>

      {rows.map((r) => (
        <div class="grid grid-cols-2 md:grid-cols-12 gap-y-2 md:gap-y-0 items-start md:items-center px-5 md:px-10 py-5 md:py-7 border-b border-white/5 last:border-0 hover:bg-white/[0.03] transition-colors group">
          <div class="col-span-2 md:col-span-3 font-display text-2xl md:text-3xl font-bold text-white/30 group-hover:text-white/50 transition-colors">{r.d}</div>
          <div class="col-span-2 md:col-span-4 font-display text-base md:text-xl text-white/40">{r.city}</div>
          <div class="col-span-2 md:col-span-4 text-white/40 text-sm md:text-base">{r.venue}</div>
          <div class="hidden md:flex md:col-span-1 justify-end">
            <span class="w-10 h-10 rounded-full border border-dashed border-white/15 flex items-center justify-center text-white/30">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 6h10M6 1v10"/></svg>
            </span>
          </div>
        </div>
      ))}

      <div class="px-6 md:px-10 py-10 text-center">
        <div class="inline-flex items-center gap-3 chip">
          <span class="w-1.5 h-1.5 rounded-full bg-gold-100 animate-pulse"></span>
          <span>{e.status}</span>
        </div>
      </div>
    </div>
  </div>
</section>
