---
import { getLangFromUrl, useTranslations, type Lang } from '~/i18n/ui';
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const items = t('marquee');

interface Props {
  reverse?: boolean;
  gradient?: boolean;
}
const { reverse = false, gradient = false } = Astro.props as Props;
const loop = [...items, ...items];
---

<div class="relative py-6 md:py-8 overflow-hidden border-y border-white/5 bg-ink-900/40 backdrop-blur-sm">
  <div class={`flex gap-10 whitespace-nowrap will-change-transform ${reverse ? 'animate-marquee-reverse' : 'animate-marquee'}`}>
    {loop.map((item, i) => (
      <div class="flex items-center gap-10 shrink-0">
        <span class={`font-display text-3xl md:text-5xl font-extrabold tracking-tight ${gradient ? 'gradient-text' : (i % 2 === 0 ? 'text-white' : 'gold-text')}`}>
          {item}
        </span>
        <span class="text-gold-500 text-2xl md:text-4xl">✦</span>
      </div>
    ))}
  </div>
</div>
