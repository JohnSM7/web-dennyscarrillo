---
import { getLangFromUrl, useTranslations, type Lang } from '~/i18n/ui';
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const f = t('footer');
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-white/5">
  <!-- Content -->
  <div class="container-x relative z-10 pt-20 pb-14">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10">
      <div class="max-w-md">
        <div class="flex items-center gap-3 mb-4">
          <img src="/logo.png" alt="DC" class="w-10 h-auto" />
          <div class="font-display font-bold text-sm tracking-[0.3em]">
            DENNYS<span class="text-gold">.</span>CARRILLO
          </div>
        </div>
        <p class="font-display text-2xl md:text-3xl italic font-light gold-text leading-tight">
          "{f.tagline}"
        </p>
      </div>

      <div class="text-white/50 text-[11px] font-mono tracking-[0.2em] uppercase md:text-right">
        <div>© {year} · {f.rights}</div>
        <div class="mt-2 text-white/40">
          {f.made}
          <a
            href="https://www.tanesolutions.com"
            target="_blank"
            rel="noopener noreferrer"
            class="ml-1 gold-text hover:opacity-80 transition-opacity"
            data-cursor="hover"
          >
            Tane Solutions
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Huge name watermark — arbitrary values para evitar fallos de purge -->
  <div class="relative select-none pointer-events-none px-3 pb-6" aria-hidden="true">
    <div
      class="text-center font-display font-black leading-[0.82] tracking-[-0.04em] whitespace-nowrap"
      style="
        font-size: clamp(3.5rem, 15vw, 13rem);
        background-image: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.04) 55%, rgba(255,255,255,0) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        -webkit-text-fill-color: transparent;
      "
    >
      <span class="block">DENNYS</span>
      <span class="block">CARRILLO</span>
    </div>
  </div>
</footer>
