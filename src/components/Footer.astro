---
import { getLangFromUrl, useTranslations, type Lang } from '~/i18n/ui';
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const f = t('footer');
const year = new Date().getFullYear();
---

<footer class="relative pt-20 pb-[clamp(6rem,22vw,18rem)] overflow-hidden border-t border-white/5">
  <!-- Huge name BG — dos líneas que siempre caben en cualquier viewport -->
  <div class="absolute inset-x-0 bottom-0 pointer-events-none select-none text-center px-2">
    <div class="font-display font-black text-[clamp(3.5rem,16vw,14rem)] leading-[0.82] tracking-[-0.04em] text-transparent bg-clip-text bg-gradient-to-b from-white/12 via-white/5 to-transparent">
      <span class="block">DENNYS</span>
      <span class="block">CARRILLO</span>
    </div>
  </div>

  <div class="container-x relative">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10 mb-16">
      <div class="max-w-md">
        <div class="flex items-center gap-3 mb-4">
          <img src="/logo.png" alt="" class="w-10 h-auto" />
          <div class="font-display font-bold text-sm tracking-[0.3em]">DENNYS<span class="text-gold">.</span>CARRILLO</div>
        </div>
        <p class="font-display text-2xl md:text-3xl italic font-light gold-text">"{f.tagline}"</p>
      </div>

      <div class="text-white/50 text-xs font-mono tracking-[0.2em] uppercase">
        <div>© {year} · {f.rights}</div>
        <div class="mt-2 text-white/40">
          {f.made}
          <a
            href="https://www.tanesolutions.com"
            target="_blank"
            rel="noopener noreferrer"
            class="ml-1 gold-text hover:opacity-80 transition-opacity"
            data-cursor="hover"
          >
            Tane Solutions
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
