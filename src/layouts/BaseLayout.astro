---
import '~/styles/global.css';
import { getLangFromUrl, useTranslations, type Lang } from '~/i18n/ui';
import Navbar from '~/components/Navbar.astro';
import Preloader from '~/components/Preloader.astro';
import Footer from '~/components/Footer.astro';
import CursorFollower from '~/components/CursorFollower.vue';
import SmoothScroll from '~/components/SmoothScroll.vue';

interface Props {
  title?: string;
  description?: string;
}

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const meta = t('meta');

const { title, description } = Astro.props;
const pageTitle = title ?? meta.title;
const pageDescription = description ?? meta.description;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang={lang} class="bg-ink-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#05030a" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="canonical" href={canonical} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content="/fotos/imgPrincipal.png" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Unbounded:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />

    <link rel="alternate" hreflang="es" href={new URL('/', Astro.site).toString()} />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).toString()} />
  </head>
  <body class="relative">
    <Preloader />
    <CursorFollower client:idle />
    <SmoothScroll client:idle />

    <!-- Gradient atmosphere -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full bg-tropic-magenta/20 blur-[140px] animate-glow"></div>
      <div class="absolute top-1/3 -right-40 w-[700px] h-[700px] rounded-full bg-tropic-aqua/15 blur-[160px] animate-glow" style="animation-delay: -1.5s"></div>
      <div class="absolute bottom-0 left-1/3 w-[500px] h-[500px] rounded-full bg-tropic-sunset/20 blur-[140px] animate-glow" style="animation-delay: -3s"></div>
      <div class="absolute inset-0 bg-ink-950/70"></div>
      <div class="noise-layer"></div>
    </div>

    <Navbar />

    <main id="main" class="relative">
      <slot />
    </main>

    <Footer />

    <script>
      // Reveal-on-scroll observer (lightweight, zero-dep)
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -80px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
